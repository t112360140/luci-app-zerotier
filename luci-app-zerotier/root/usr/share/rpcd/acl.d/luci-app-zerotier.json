{
	"luci-app-zerotier": {
		"description": "Grant access to ZeroTier configuration",
		"read": {
			"file": {
				"/sbin/ifconfig": [ "exec" ],
				"/usr/bin/curl": [ "exec" ],
				"/var/lib/zerotier-one/authtoken.secret": [ "read" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "zerotier" ]
		},
		"write": {
			"uci": [ "zerotier" ]
		}
	}
}
